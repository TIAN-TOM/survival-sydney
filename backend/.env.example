MONGODB_URI=mongodb://localhost:27017/openassess
# REQUIRED: generate a fresh, high-entropy value per environment, e.g. `openssl rand -hex 32`.
# The app refuses to start on this placeholder or any secret shorter than 32 characters.
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32
JWT_EXPIRES_IN=2h
BCRYPT_ROUNDS=10
CLIENT_ORIGIN=http://localhost:5173
PORT=5001
# Set to "true" only when the API runs behind a reverse proxy (enables X-Forwarded-For for rate limits).
TRUST_PROXY=false
