# ---------------------------------------------------------------------------
# Self-host (docker compose) settings
# ---------------------------------------------------------------------------
# These are consumed by docker-compose.yml. Copy this file to .env before
# running `docker compose up`.
#
# (This is the ROOT compose env file. The app's own defaults live in
#  backend/.env.example and frontend/.env.example for non-Docker local dev.)

# REQUIRED. High-entropy signing key. Generate a fresh value per environment:
#   openssl rand -hex 32
# The backend refuses to boot on a known placeholder or anything under 32 chars.
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32

# Public URL users visit; used for the CORS allow-list. With the bundled
# nginx frontend this is the frontend origin.
CLIENT_ORIGIN=http://localhost:8080

# Host port the bundled frontend (nginx) is published on. The container
# always listens on 80 internally; this only changes the host mapping.
FRONTEND_PORT=8080

# Optional token/auth tuning (defaults shown).
JWT_EXPIRES_IN=2h
BCRYPT_ROUNDS=10

# NOTE: In the compose setup MONGODB_URI is fixed to
# mongodb://mongo:27017/survival_sydney (the internal service network) and
# TRUST_PROXY is forced to "true" because the API runs behind nginx.
# You do not need to set them here.
