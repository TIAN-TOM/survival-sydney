{
  "info": {
    "name": "COMP5347 Quiz API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5001/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "attemptToken", "value": "" },
    { "key": "scoreId", "value": "" },
    { "key": "questionId1", "value": "" },
    { "key": "questionId2", "value": "" },
    { "key": "questionId3", "value": "" },
    { "key": "questionId4", "value": "" },
    { "key": "questionId5", "value": "" },
    { "key": "questionId6", "value": "" },
    { "key": "questionId7", "value": "" },
    { "key": "questionId8", "value": "" },
    { "key": "questionId9", "value": "" },
    { "key": "questionId10", "value": "" },
    { "key": "adminQuestionId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth - Register player",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"demo\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"Password123\"\n}"
        }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.success && json.data?.user) {", "  pm.test('No JWT on register', () => pm.expect(json.data.token).to.be.undefined);", "}"] } }]
    },
    {
      "name": "Auth - Login seeded player",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"player1\",\n  \"password\": \"PlayerPass123\"\n}"
        }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.success && json.data?.token) pm.collectionVariables.set('token', json.data.token);"] } }]
    },
    {
      "name": "Quiz - Start",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "url": "{{baseUrl}}/quiz/start"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
            "const data = pm.response.json().data;",
            "if (data?.attemptToken) pm.collectionVariables.set('attemptToken', data.attemptToken);",
            "(data?.questions || []).forEach((question, index) => {",
            "  const position = index + 1;",
            "  pm.collectionVariables.set(`questionId${position}`, question._id);",
            "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Quiz - Submit",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/quiz/submit",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"attemptToken\": \"{{attemptToken}}\",\n  \"answers\": [\n    { \"questionId\": \"{{questionId1}}\", \"selectedAnswer\": 0 },\n    { \"questionId\": \"{{questionId2}}\", \"selectedAnswer\": 0 },\n    { \"questionId\": \"{{questionId3}}\", \"selectedAnswer\": 0 },\n    { \"questionId\": \"{{questionId4}}\", \"selectedAnswer\": 0 },\n    { \"questionId\": \"{{questionId5}}\", \"selectedAnswer\": 0 },\n    { \"questionId\": \"{{questionId6}}\", \"selectedAnswer\": 0 },\n    { \"questionId\": \"{{questionId7}}\", \"selectedAnswer\": 0 },\n    { \"questionId\": \"{{questionId8}}\", \"selectedAnswer\": 0 },\n    { \"questionId\": \"{{questionId9}}\", \"selectedAnswer\": 0 },\n    { \"questionId\": \"{{questionId10}}\", \"selectedAnswer\": 0 }\n  ]\n}"
        }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.success && json.data?.scoreId) pm.collectionVariables.set('scoreId', json.data.scoreId);"] } }]
    },
    {
      "name": "Quiz - History",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "url": "{{baseUrl}}/quiz/history"
      }
    },
    {
      "name": "Quiz - Review attempt detail",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "url": "{{baseUrl}}/quiz/history/{{scoreId}}"
      }
    },
    {
      "name": "Quiz - Leaderboard",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
        },
        "url": "{{baseUrl}}/quiz/leaderboard"
      }
    },
    {
      "name": "Auth - Login admin",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"AdminPass123\"\n}"
        }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.success && json.data?.token) pm.collectionVariables.set('adminToken', json.data.token);"] } }]
    },
    {
      "name": "Admin - List questions",
      "request": {
        "method": "GET",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "url": "{{baseUrl}}/admin/questions"
      }
    },
    {
      "name": "Admin - Create question",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/admin/questions",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"questionText\": \"In Sydney, which public transport modes are common?\",\n  \"options\": [\"Only trains\", \"Only buses\", \"Trains, buses, light rail, and ferries\", \"Only rideshare\"],\n  \"correctAnswer\": 2,\n  \"explanation\": \"Sydney transport includes several public transport modes.\",\n  \"active\": true\n}"
        }
      },
      "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "const id = json.data?._id;", "if (json.success && id) pm.collectionVariables.set('adminQuestionId', id);"] } }]
    },
    {
      "name": "Admin - Edit question",
      "request": {
        "method": "PUT",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/admin/questions/{{adminQuestionId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"questionText\": \"In Sydney, what should you usually do when using train, bus, light rail, or ferry services?\",\n  \"options\": [\"Use the same card or device to tap on and off\", \"Tap on only\", \"Change cards every trip\", \"Assume every trip is free\"],\n  \"correctAnswer\": 0,\n  \"explanation\": \"Using the same card or device avoids incorrect fare calculation.\",\n  \"active\": true\n}"
        }
      }
    },
    {
      "name": "Admin - Toggle active",
      "request": {
        "method": "PATCH",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "url": "{{baseUrl}}/admin/questions/{{adminQuestionId}}/toggle"
      }
    },
    {
      "name": "Admin - Delete question",
      "request": {
        "method": "DELETE",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "url": "{{baseUrl}}/admin/questions/{{adminQuestionId}}"
      }
    },
    {
      "name": "Admin - Bulk import",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/admin/questions/bulk-import",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"questions\": [\n    {\n      \"questionText\": \"What is the usual maximum NSW rental bond?\",\n      \"options\": [\"1 week rent\", \"2 weeks rent\", \"4 weeks rent\", \"6 months rent\"],\n      \"correctAnswer\": 2,\n      \"explanation\": \"This reflects the standard NSW rental bond cap used by the demo bank.\",\n      \"active\": true\n    }\n  ]\n}"
        }
      }
    },
    {
      "name": "Admin - Bulk import invalid item",
      "request": {
        "method": "POST",
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
        },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": "{{baseUrl}}/admin/questions/bulk-import",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"questions\": [\n    {\n      \"questionText\": \"Valid Sydney life question?\",\n      \"options\": [\"A\", \"B\", \"C\", \"D\"],\n      \"correctAnswer\": 0,\n      \"explanation\": \"Valid row.\",\n      \"active\": true\n    },\n    {\n      \"questionText\": \"Invalid Sydney life question?\",\n      \"options\": [\"A\", \"B\", \"C\", \"D\"],\n      \"correctAnswer\": 4,\n      \"explanation\": \"This row should fail because the answer index is out of range.\",\n      \"active\": true\n    }\n  ]\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('invalid bulk import returns 400', () => pm.response.to.have.status(400));",
              "const json = pm.response.json();",
              "pm.test('failure envelope is returned', () => pm.expect(json.success).to.equal(false));",
              "pm.test('invalid row index is reported in error message', () => pm.expect(json.error).to.include('Question 2:'));",
              "pm.test('failure body matches spec envelope fields only', () => pm.expect(Object.keys(json).sort()).to.eql(['error', 'success']));"
            ]
          }
        }
      ]
    },
    { "name": "Docs - Swagger", "request": { "method": "GET", "url": "http://localhost:5001/api-docs" } }
  ]
}
